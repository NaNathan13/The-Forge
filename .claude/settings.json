{
  "_comment": "Hook scaffolding for The Forge pipeline. Add project-specific PreToolUse hooks under .claude/hooks/ and register them below. See docs/dev/setup.md for guidance.",
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline/budget-mirror.sh"
  },
  "permissions": {
    "ask": [
      "Read(docs/how-the-forge-works.md)",
      "Read(docs/audit/**)",
      "Read(docs/vision/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/mission-control-drift.sh" },
          { "type": "command", "command": ".claude/hooks/overseer-session-start.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/overseer-stop-handoff.sh" }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/instructions-loaded.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/read-human-only-guard.sh" }
        ]
      }
    ]
  }
}
