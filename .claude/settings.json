{
  "_comment": "Hook scaffolding for The Forge pipeline. Add project-specific PreToolUse hooks under .claude/hooks/ and register them below. See docs/dev/setup.md for guidance.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/mission-control-drift.sh" },
          { "type": "command", "command": ".claude/hooks/forge-session-start.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/forge-stop-handoff.sh" }
        ]
      }
    ]
  }
}
