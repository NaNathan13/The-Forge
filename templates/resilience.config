# .forge/resilience.config — P2 single-session resilience tunables.
#
# PLACEHOLDER — shipped by light-the-forge.sh to new projects as
# `.forge/resilience.config`. Carries The Forge's §Q1 defaults; a project tunes
# them here rather than editing scripts. Keep this mirrored with The Forge's own
# `.forge/resilience.config` whenever the *schema* changes (CLAUDE.md rule:
# structural changes to a root/.forge doc mirror into templates/).
#
# A bash-sourceable KEY=value file. The relaunch loop, the Stop / SessionStart
# hooks, the liveness watchdog, and the continuation helper all `source` this to
# resolve their thresholds. This file is COMMITTED to git (the runtime dirs it
# points at — .forge/continuation/ and .forge/heartbeat/ — are gitignored,
# this is not).
#
# Sourced, not executed: no shebang, no logic, only `KEY=value` lines and
# comments. Keep it that way — `source`-ing arbitrary logic is a footgun.

# ── Context-window thresholds (design doc §Q1) ───────────────────────────────
# Percent of the context window used. The relaunch loop reads real token counts
# from each generation's `claude -p --output-format json` `.usage` block and
# compares against the role's warn / hard pair:
#   used < warn          → relaunch normally
#   warn <= used < hard  → relaunch, signal next generation to hand off promptly
#   used >= hard         → must hand off this generation; no generation starts
#                          that would run past hard without a handoff
#
# Orchestrator = Tier 0 / Tier 1, long-lived. Hands off early (40/50) — its
# context is load-bearing state. Do not raise these.
FORGE_ORCH_WARN_PCT=40
FORGE_ORCH_HARD_PCT=50

# Worker = Tier 2, ephemeral. More runway (50/60) — its context is mostly
# scratch and it returns a structured sentinel.
FORGE_WORKER_WARN_PCT=50
FORGE_WORKER_HARD_PCT=60

# Total context window size, in tokens — the denominator for the percentage.
# Adjust if your model's window differs.
FORGE_CONTEXT_WINDOW_TOKENS=200000

# ── Relaunch-loop throttle ───────────────────────────────────────────────────
# Minimum seconds between relaunches. Guards handoff-thrash spin at the loop
# level (launchd guards process-crash thrash at the supervisor level).
FORGE_THROTTLE_SECONDS=10

# ── Thrash circuit breaker (design doc §2 / §Q3) ─────────────────────────────
# If more than FORGE_THRASH_MAX_GENERATIONS handoffs happen within
# FORGE_THRASH_WINDOW_SECONDS, the relaunch loop trips its breaker and exits
# non-zero so a human is alerted. An infinite hand-off loop is a bug.
FORGE_THRASH_MAX_GENERATIONS=5
FORGE_THRASH_WINDOW_SECONDS=300

# ── Crash-respin circuit breaker (sub-phase 3d) ──────────────────────────────
# Distinct from the handoff breaker above: that one counts clean
# FORGE_CONTINUE handoffs within a single loop process; this one counts CRASH
# respawns across loop processes (each crash exits the loop; launchd respawns
# it; the counter persists to see the cycle). Trips when more than
# FORGE_CRASH_MAX_RESPINS crashes happen within FORGE_CRASH_WINDOW_SECONDS,
# writes a stay-down sentinel, and halts launchd respawn (via the plist's
# KeepAlive.SuccessfulExit=false). Defaults intentionally match the handoff
# breaker. See docs/workflow/p2-resilience-operations.md for recovery.
FORGE_CRASH_MAX_RESPINS=5
FORGE_CRASH_WINDOW_SECONDS=300

# ── Liveness watchdog ────────────────────────────────────────────────────────
# Heartbeat age, in seconds, past which the watchdog treats a session as hung.
# The Stop hook touches .forge/heartbeat/<slug> on every fire.
FORGE_HEARTBEAT_TIMEOUT_SECONDS=900

# ── Continuation retention ───────────────────────────────────────────────────
# How many gen-NNN.md generations to keep per session slug. The continuation
# helper prunes older generations past this cap after each write.
FORGE_RETENTION_CAP=20
